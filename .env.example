# GoalSlay Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# Use one of: PostgreSQL (recommended) or SQL Server

# -----------------------------------------------------------------------------
# Individual connection variables (used when DATABASE_URL not set)
# -----------------------------------------------------------------------------
DB_SERVER=""
DB_PORT=5432
DB_NAME=""
DB_USER="username"
DB_KEY="your-database-password"

# -----------------------------------------------------------------------------
# Connection URL (pick one)
# -----------------------------------------------------------------------------
# For PostgreSQL (Azure PostgreSQL Flexible Server, local PG, etc.):
DATABASE_URL="postgresql://username:password@your-server.postgres.database.azure.com:5432/goalslay?connection_limit=1"

# For SQL Server (if using Azure SQL / SQL Server instead):
# DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=goalslay;user=username;password=your-password;encrypt=true"

# For npx prisma (when URL contains special characters, use URL-encoded value):
# DATABASE_URL_ENCODED="postgresql%3A%2F%2Fuser%3Apass%40host%3A5432%2Fdb"

# -----------------------------------------------------------------------------
# PgBouncer (connection pooling) – Azure PostgreSQL with PgBouncer
# -----------------------------------------------------------------------------
# Direct PostgreSQL (default)
USE_PGBOUNCER=false
# DB_PORT=5432

# With PgBouncer (production / flexible server)
# USE_PGBOUNCER=true
# DB_PORT=6432
# DATABASE_URL="postgresql://username:password@your-server.postgres.database.azure.com:6432/goalslay?pgbouncer=true&connection_limit=1"

# =============================================================================
# AUTHENTICATION (Better Auth)
# =============================================================================
BETTER_AUTH_SECRET="your-secret-key-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

TWO_FACTOR_ENCRYPTION_KEY="TOODsetME"

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# Choose provider: "openai" (local dev) or "azure" (enterprise)
LLM_PROVIDER="openai"

# -----------------------------------------------------------------------------
# Option 1: LOCAL DEVELOPMENT (OpenAI Direct)
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-your-openai-api-key"

# -----------------------------------------------------------------------------
# Option 2: ENTERPRISE (Azure OpenAI)
# -----------------------------------------------------------------------------
# AZURE_OPENAI_API_KEY="your-azure-openai-key"
# AZURE_OPENAI_ENDPOINT="https://your-instance.openai.azure.com"
# AZURE_OPENAI_DEPLOYMENT="gpt-4o"
# AZURE_OPENAI_API_VERSION="2024-02-15-preview"

# =============================================================================
# LANGCHAIN (Optional – tracing/debugging)
# =============================================================================
# LANGCHAIN_TRACING_V2="true"
# LANGCHAIN_API_KEY="lsv2_your_langsmith_key"
# LANGCHAIN_PROJECT="goalslay"

# =============================================================================
# EMAIL NOTIFICATIONS (Azure Communication Services)
# =============================================================================
# AZURE_CONNECTION_STRING="endpoint=https://your-acs.communication.azure.com/;accesskey=key"
# AZURE_SENDER_EMAIL="DoNotReply@your-domain.com"

# =============================================================================
# CRON / SCHEDULED JOBS
# =============================================================================
CRON_SECRET="your-cron-secret-key"

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
